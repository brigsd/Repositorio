# Conexão com o banco Postgres
# No Render, vem automaticamente via render.yaml
# Local: a string que aparece no painel do Render do banco
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Chave da API da Anthropic
# Crie em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Segredo de autenticação
# Gere com: openssl rand -base64 32
AUTH_SECRET=

# URL da aplicação (usada em magic links de auth)
# Local: http://localhost:3000
# Render: https://seu-app.onrender.com
APP_URL=http://localhost:3000
