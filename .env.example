# Conexão com o banco Postgres (Neon free tier)
# Pegue em: https://console.neon.tech → seu projeto → Connection Details
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Chave da API da Anthropic
# Crie em https://console.anthropic.com/settings/keys
# Opcional para dev: exercícios da A.6 funcionam sem (feedback curado)
ANTHROPIC_API_KEY=sk-ant-...

# Segredo de autenticação (qualquer string aleatória em dev)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# URL da aplicação
# Local: http://localhost:3000
# Produção: https://seu-app.onrender.com
APP_URL=http://localhost:3000
